<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APK Dialog Injector"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <!-- בחירת APK -->
        <Button
            android:id="@+id/btnSelectApk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="בחר APK"
            android:backgroundTint="#3F51B5"/>

        <TextView
            android:id="@+id/tvApkPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="לא נבחר קובץ"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"/>

        <!-- כותרת -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="כותרת הדיאלוג"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="הכנס כותרת..."
            android:background="@drawable/edit_text_bg"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- תיאור -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="תיאור הדיאלוג"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="הכנס תיאור..."
            android:minLines="3"
            android:gravity="top"
            android:background="@drawable/edit_text_bg"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- כפתורים -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="שם כפתור 1"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etButton1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="כפתור 1..."
            android:background="@drawable/edit_text_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="שם כפתור 2"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etButton2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="כפתור 2..."
            android:background="@drawable/edit_text_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="שם כפתור 3"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etButton3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="כפתור 3..."
            android:background="@drawable/edit_text_bg"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- כפתורי פעולה -->
        <Button
            android:id="@+id/btnInject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="הזרק דיאלוג"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnRemove"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מחק דיאלוג"
            android:backgroundTint="#F44336"
            android:layout_marginBottom="16dp"/>

        <!-- לוג -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="לוג:"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ממתין לפעולה..."
            android:textColor="#FFFFFF"
            android:background="#212121"
            android:padding="10dp"
            android:fontFamily="monospace"
            android:minLines="5"/>

    </LinearLayout>
</ScrollView>
